# MongoDB
MONGO_URI=mongodb://localhost:27017/gadgetgo

# JWT
JWT_SECRET=shan

# Server
PORT=5000

# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google OAuth 2.0 (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Email — Gmail SMTP (use App Password, not your real password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Frontend URL
CLIENT_URL=http://localhost:3000

# Session secret (for passport)
SESSION_SECRET=change-this-too

# Razorpay Payment Gateway (https://dashboard.razorpay.com/)
# Get keys from: Dashboard -> Settings -> API Keys -> Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Your backend URL
BACKEND_URL=http://localhost:5000
